# ================= airastats.uz environment template =================
# Copy to ".env" and fill in real values:  cp .env.example .env
# NEVER commit the real .env.

# ---- Security ----
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# NEVER put the real key here — this file is committed. The real key lives in .env only.
SECRET_KEY=change-me-generate-a-fresh-random-key
# Production: False. (Triggers HTTPS/HSTS/secure-cookie hardening.)
DEBUG=False
# Comma-separated. Use your real domain(s) in production.
ALLOWED_HOSTS=airastats.uz,www.airastats.uz
# Only needed behind HTTPS proxy/tunnel. Full origins, comma-separated.
CSRF_TRUSTED_ORIGINS=https://airastats.uz,https://www.airastats.uz

# Set False if TLS is NOT yet terminated in front of the app (avoids redirect loop).
SECURE_SSL_REDIRECT=True

TIME_ZONE=Asia/Tashkent
LOG_LEVEL=INFO

# ---- Database ----
# With docker compose, DB_HOST/DB_PORT are overridden to point at the "db" service.
DB_NAME=aira
DB_USER=aira
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

# ---- Public ports (host side, served by nginx) ----
HTTP_PORT=80
HTTPS_PORT=443

# ---- Gunicorn tuning (optional) ----
# GUNICORN_WORKERS=3
# GUNICORN_TIMEOUT=120